# VOICECODE 環境変数テンプレート
# このファイルをコピーして .env を作成してください

# アプリケーション設定
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-here

# データベース
DATABASE_URL=sqlite:///./voicecode.db

# ファイルパス
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
WORLDVIEW_THEME=elements_v1

# LINE Bot (Phase 2で設定)
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# 公開サーバーURL（本番デプロイ後に必ず設定）
BASE_URL=https://あなたのドメイン.railway.app

# Stripe (Phase 2で設定)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# 診断設定
DIAGNOSIS_PRICE_YEN=3000
MIN_AUDIO_DURATION_SEC=15
MAX_AUDIO_DURATION_SEC=180
